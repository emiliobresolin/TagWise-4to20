TAGWISE_DEPLOYMENT_ENV=production
TAGWISE_NODE_ENV=production
TAGWISE_HOST=0.0.0.0
TAGWISE_API_PORT=4100
TAGWISE_WORKER_PORT=4101
TAGWISE_DATABASE_URL=postgres://tagwise_app:<set-in-secret-manager>@<production-postgres-host>:5432/tagwise
TAGWISE_STORAGE_BUCKET=tagwise-evidence-production
TAGWISE_STORAGE_REGION=us-east-1
TAGWISE_STORAGE_ACCESS_KEY_ID=<set-in-secret-manager>
TAGWISE_STORAGE_SECRET_ACCESS_KEY=<set-in-secret-manager>
TAGWISE_STORAGE_FORCE_PATH_STYLE=false
TAGWISE_STORAGE_AUTO_CREATE_BUCKET=false
TAGWISE_AUTH_TOKEN_SECRET=<set-in-secret-manager>
TAGWISE_AUTH_ACCESS_TOKEN_TTL_SECONDS=900
TAGWISE_AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
TAGWISE_SEED_TECHNICIAN_EMAIL=<production-technician-email>
TAGWISE_SEED_TECHNICIAN_PASSWORD=<set-in-secret-manager>
TAGWISE_SEED_TECHNICIAN_DISPLAY_NAME=Field Technician
TAGWISE_SEED_SUPERVISOR_EMAIL=<production-supervisor-email>
TAGWISE_SEED_SUPERVISOR_PASSWORD=<set-in-secret-manager>
TAGWISE_SEED_SUPERVISOR_DISPLAY_NAME=Field Supervisor
TAGWISE_SEED_MANAGER_EMAIL=<production-manager-email>
TAGWISE_SEED_MANAGER_PASSWORD=<set-in-secret-manager>
TAGWISE_SEED_MANAGER_DISPLAY_NAME=Operations Manager
