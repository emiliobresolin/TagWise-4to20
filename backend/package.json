{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:api": "tsx watch src/api/main.ts",
    "dev:worker": "tsx watch src/worker/main.ts",
    "start:api": "tsx src/api/main.ts",
    "start:worker": "tsx src/worker/main.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/platform/db/runMigrationsCli.ts",
    "storage:smoke": "tsx src/platform/storage/runObjectStorageSmokeCli.ts",
    "deploy:preflight": "tsx src/ops/deploymentPreflightCli.ts",
    "release:smoke": "tsx src/ops/releaseSmokeCli.ts",
    "release:observability": "tsx src/ops/releaseObservabilityCli.ts",
    "backup:restore:verify": "tsx src/ops/backupRestoreVerificationCli.ts",
    "worker:resilience:drill": "tsx src/ops/workerResilienceDrillCli.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.911.0",
    "@aws-sdk/s3-request-presigner": "^3.911.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.5",
    "pg-mem": "^3.0.5",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2",
    "vitest": "^4.1.4"
  }
}
